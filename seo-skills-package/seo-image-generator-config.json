{
  "providers": {
    "primary": "openai",
    "fallbacks": ["minimax", "google"],
    "openai": {
      "model": "gpt-image-1",
      "api_key_env": "OPENAI_API_KEY"
    },
    "minimax": {
      "model": "image-01",
      "api_key_env": "MINIMAX_API_KEY"
    },
    "google": {
      "model": "gemini-3.1-flash-image-preview",
      "api_key_env": "GEMINI_API_KEY"
    }
  },
  "output_dir": "../outputs",
  "format": "webp"
}
